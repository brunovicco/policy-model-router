APP_ENV=development
LOG_LEVEL=INFO
LOG_FORMAT=json

# Required: JSON object mapping each agent_name to its own API key, checked against the
# X-API-Key header on POST /route. The service refuses to start if this is unset, empty, or not
# a JSON object of non-empty string agent_name/key pairs. Use long, random values per agent and
# per environment; never commit real keys.
# Example: API_KEYS={"credit-analysis-agent":"REPLACE_ME","reporting-agent":"REPLACE_ME"}
API_KEYS=

# Rate limit for POST /route, keyed by (client IP, agent_name). Defaults shown.
# RATE_LIMIT_MAX_REQUESTS=60
# RATE_LIMIT_WINDOW_SECONDS=60

# A second, lighter rate-limit tier keyed by client IP alone (checked before the per-agent tier
# above, and before authentication): closes the bypass where a caller varies agent_name on every
# attempt to dodge the per-agent limit. Shares RATE_LIMIT_WINDOW_SECONDS. Default shown.
# RATE_LIMIT_PER_IP_MAX_REQUESTS=600

# In-memory limiter only (ignored once REDIS_URL is set): caps how many distinct
# (client IP, agent_name) keys are held in memory at once, evicting the least-recently-touched
# key past this limit, so an unbounded number of distinct keys cannot grow this process's memory
# without bound. Default shown.
# RATE_LIMIT_MAX_TRACKED_KEYS=100000

# Redis-backed limiter only: HMAC key for the fingerprint logged when the rate limiter fails
# open (never the raw key itself, which embeds the caller's IP). Optional: unset, a random
# per-process secret is used instead, which still keeps the fingerprint non-reversible from log
# access alone but does not stay stable across restarts. Treat this as a secret if set.
# RATE_LIMIT_FINGERPRINT_SECRET=

# Optional: share the rate limit across replicas via Redis (ADR-0008). Requires
# `uv sync --extra rate-limit`. Leave unset to keep the default in-memory, per-process limiter
# (fine for a single instance; each replica enforces its own limit otherwise).
# REDIS_URL=redis://localhost:6379/0

# Serve /docs, /redoc, and /openapi.json. Disabled by default (deny by default); set to true for
# local development only.
# ENABLE_API_DOCS=false

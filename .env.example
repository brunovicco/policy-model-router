APP_ENV=development
LOG_LEVEL=INFO
LOG_FORMAT=json
SERVICE_NAME=policy-model-router

# Required: JSON object mapping each agent_name to its own API key, checked against the
# X-API-Key header on POST /route. The service refuses to start if this is unset, empty, or not
# a JSON object of non-empty string agent_name/key pairs. Use long, random values per agent and
# per environment; never commit real keys.
# Example: API_KEYS={"credit-analysis-agent":"REPLACE_ME","reporting-agent":"REPLACE_ME"}
API_KEYS=

# Optional: in-memory rate limit for POST /route, keyed by (client IP, agent_name).
# Per-process only - not shared across replicas. Defaults shown.
# RATE_LIMIT_MAX_REQUESTS=60
# RATE_LIMIT_WINDOW_SECONDS=60

# Optional Langfuse tracing (opt-in; see docs/LLM_OBSERVABILITY.md).
# Leave unset to keep tracing disabled. Requires `uv sync --extra tracing`.
# LANGFUSE_PUBLIC_KEY=
# LANGFUSE_SECRET_KEY=
# LANGFUSE_BASE_URL=https://cloud.langfuse.com
# LANGFUSE_CAPTURE_CONTENT=false
